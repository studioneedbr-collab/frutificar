# ─────────────────────────────────────────────────────────────
# Frutificar Digital — variáveis de ambiente
# Copie para .env.local (dev) e configure na Vercel (produção).
# ─────────────────────────────────────────────────────────────

# ── Preview ──────────────────────────────────────────────────
# true  = libera todas as rotas sem login/banco (modo de visualização atual)
# false = ativa autenticação + controle de plano (use em produção)
PREVIEW_MODE="true"

# ── Banco de dados (Supabase Postgres) ───────────────────────
# DATABASE_URL: conexão via POOLER (porta 6543) — usada pela aplicação em runtime.
# DIRECT_URL:   conexão DIRETA (porta 5432) — usada por `prisma migrate`/`db push`.
# Pegue ambas em: Supabase > Project Settings > Database > Connection string.
DATABASE_URL="postgresql://postgres.[ref]:[senha]@aws-0-[regiao].pooler.supabase.com:6543/postgres?pgbouncer=true"
DIRECT_URL="postgresql://postgres.[ref]:[senha]@aws-0-[regiao].pooler.supabase.com:5432/postgres"

# ── Autenticação (next-auth v5 / Auth.js) ────────────────────
# Gere um segredo com: openssl rand -base64 32
AUTH_SECRET="troque-por-um-segredo-de-32+-caracteres"
# Em produção a Vercel define a URL automaticamente; em dev pode deixar localhost.
AUTH_URL="http://localhost:3000"

# ── OpenAI (Chat IA Agrícola) ────────────────────────────────
OPENAI_API_KEY="sk-..."

# ─────────────────────────────────────────────────────────────
# Integrações futuras (ainda não exigidas pelo código — opcional)
# ─────────────────────────────────────────────────────────────

# Asaas — pagamentos (sandbox por padrão)
ASAAS_API_KEY=
ASAAS_API_URL=https://sandbox.asaas.com/api/v3
ASAAS_WEBHOOK_TOKEN=

# YouTube Data API — vídeos de cursos/lives
# YOUTUBE_API_KEY=""

# E-mail transacional (Brevo) — obrigatório para envio real de e-mails
# Pegue a chave em: Brevo > SMTP & API > API Keys (formato xkeysib-...)
# BREVO_API_KEY=""
# Remetente (precisa estar VERIFICADO no Brevo)
# EMAIL_FROM="frutificardigital@gmail.com"
# EMAIL_FROM_NAME="Frutificar Digital"
# Destinatário dos avisos de novo cadastro
# ADMIN_NOTIFICATION_EMAIL="frutificardigital@gmail.com"

# ── Supabase Storage (upload de materiais, áudios de podcast, etc.) ──
# 1) Storage → New bucket → nome "uploads" → marque "Public bucket".
# 2) Settings → API → copie a chave "service_role" para SUPABASE_SERVICE_ROLE_KEY.
# SUPABASE_URL é opcional (derivada do DATABASE_URL se ausente).
# SUPABASE_URL="https://[ref].supabase.co"
# SUPABASE_SERVICE_ROLE_KEY=""
# SUPABASE_STORAGE_BUCKET="uploads"
